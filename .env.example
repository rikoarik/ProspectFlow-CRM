# Supabase (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-only, never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI-compatible endpoint for the AI mockup generator.
# Works with OpenAI, OpenRouter, Together, LM Studio, vLLM, etc.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Storage bucket for generated mockup HTML files.
SUPABASE_STORAGE_BUCKET_MOCKUPS=mockups

# S3-compatible endpoint + region for direct Storage access (optional).
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_REGION=

# Override base for resolving Storage object public URLs (optional).
# When set, replaces URLs returned by supabase.storage.getPublicUrl().
SUPABASE_STORAGE_PUBLIC_BASE_URL=